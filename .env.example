# Configuração AGT - Facturação Electrónica
# Copie este ficheiro para .env e preencha os valores

# Número de identificação fiscal (NIF)
AGT_TAX_ID=5000000000

# Nome do software (product ID)
AGT_PRODUCT_ID=MeuSoftware

# Versão do software
AGT_PRODUCT_VERSION=1.0.0

# Número de validação do software (obtido na AGT)
AGT_VALIDATION_NUMBER=0000

# Ambiente: hml (homologação) ou prod (produção)
AGT_ENVIRONMENT=hml

# Caminho para o ficheiro da chave privada PEM
AGT_PRIVATE_KEY_PATH=./keys/private_key.pem

# Ou colar a chave privada directamente (não recomendado)
# AGT_PRIVATE_KEY_PEM=-----BEGIN PRIVATE KEY-----...
